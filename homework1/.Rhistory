#train_df <- df[train,]
#test_df <- df[-train,]
y_train <- as.factor(y_train)
#Scale
x_train <- scale(x_train)
x_test  <- scale(x_test,
center = attr(x_train, "scaled:center"),
scale  = attr(x_train, "scaled:scale"))
max_k <- 0
for (k in 1:30) {
pred <- knn(x_train, x_test, y_train, k = k) # run classifier
acc <- mean(pred == test_df$CHD)
if (max_k < acc) { # check if performance is better
max_k <- acc #if so, save it
}
}
