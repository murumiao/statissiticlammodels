library(tidyverse)
library(ISLR2)
library(glmnet)
library(readr)
library(tree)
library(randomForest)
library(gbm)
}
{
dataf <- read_delim("db.txt",delim = "\t", escape_double = FALSE, trim_ws = TRUE )
}
#View(dataf)
head(dataf)
# Data Preprocessing ------------------------------------------------------
### Binarize variable progr
binary_threshold<-150
dataf <- as_tibble(dataf) %>%
mutate(progress = cut(progr, c(-Inf, binary_threshold, Inf), c("Low", "High"))) %>%
select(-progr)
# Data Exploration --------------------------------------------------------
#cor(dataf)
#library('corrplot')
#cor_matrix <- cor(dataf)
#corrplot(cor_matrix, method = "color", type = "upper", tl.col = "black", tl.srt = 45, mar = c(0, 0, 1, 0), tl.cex = 0.7)
# Nota: HDL (TCH)con tutto, CD-LDL
# Data Split --------------------------------------------------------------
{
set.seed(1)
x <- model.matrix(progress ~ ., data=dataf)[, -12] # trim off the last column (i.e., keep only the predictors)
y <- dataf$progress
train <- sample(1:nrow(x), nrow(x)/2)
test <- -train # numerical indexes, so we complement with -
y_test <- y[test]
x_train <- x[train, ]
y_train <- y[train]
x_test <- x[test, ]
}
{
set.seed(1)
boosted <- gbm(progress ~ ., data=x_train, distribution="bernoulli", n.trees=5000, interaction.depth=4)
# Plots
knitr::kable(summary(boosted))
plot(boosted, i="TG")
plot(boosted, i="BP")
yhat.boost <- predict(boosted, newdata=x_test, n.trees=5000)
mean((yhat.boost > 0.5) != y_test)
}
{
set.seed(1)
boosted <- gbm(progress ~ ., data=x_train, distribution="bernoulli", n.trees=5000, interaction.depth=4)
# Plots
knitr::kable(summary(boosted))
plot(boosted, i="TG")
plot(boosted, i="BP")
yhat.boost <- predict(boosted, newdata=x_test, n.trees=5000)
}
{
set.seed(1)
boosted <- gbm(progress ~ ., data=x_train, distribution="gaussian", n.trees=5000, interaction.depth=4)
# Plots
knitr::kable(summary(boosted))
plot(boosted, i="TG")
plot(boosted, i="BP")
yhat.boost <- predict(boosted, newdata=x_test, n.trees=5000)
}
