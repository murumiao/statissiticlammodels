# Load Dataset ------------------------------------------------------------
{
library(tidyverse)
library(ISLR2)
library(glmnet)
library(readr)
library(tree)
library(randomForest)
library(gbm)
}
{
dataf <- read_delim("db.txt",delim = "\t", escape_double = FALSE, trim_ws = TRUE)
}
#View(dataf)
head(dataf)
# Data Preprocessing ------------------------------------------------------
# Data Exploration --------------------------------------------------------
#cor(dataf)
#library('corrplot')
#cor_matrix <- cor(dataf)
#corrplot(cor_matrix, method = "color", type = "upper", tl.col = "black", tl.srt = 45, mar = c(0, 0, 1, 0), tl.cex = 0.7)
# Nota: HDL (TCH)con tutto, CD-LDL
# Data Split --------------------------------------------------------------
{
set.seed(1)
x <- model.matrix(progr ~ ., data=dataf)[, -12] # trim off the last column (i.e., keep only the predictors)
y <- dataf$progr
train <- sample(1:nrow(x), nrow(x)/2)
test <- -train # numerical indexes, so we complement with -
y_test <- y[test]
x_train <- x[train, ]
y_train <- y[train]
x_test <- x[test, ]
}
{
set.seed(1)
boosted <- gbm(progr ~ ., data=x_train, distribution="gaussian", n.trees=5000, interaction.depth=4)
# Plots
knitr::kable(summary(boosted))
plot(boosted, i="TG")
plot(boosted, i="BP")
yhat.boost <- predict(boosted, newdata=x_test, n.trees=5000)
}
set.seed(1)
boosted <- gbm(progr ~ ., data=x_train, distribution="gaussian", n.trees=5000, interaction.depth=4)
boosted <- gbm(progr ~ ., data=as.data.frame(x_train), distribution="gaussian", n.trees=5000, interaction.depth=4)
View(x_train)
boosted <- gbm(progr ~ ., data=dataf, subset=x_train, distribution="gaussian", n.trees=5000, interaction.depth=4)
boosted <- gbm(progr ~ ., data=dataf, i.train=x_train, distribution="gaussian", n.trees=5000, interaction.depth=4)
boosted <- gbm(progr ~ ., data=x_train, distribution="gaussian", n.trees=5000, interaction.depth=4)
# Tree --------------------------------------------------------------------
set.seed(1)
tree.train <- tree(progr ~., data=dataf, subset=x_train)
summary(tree.train) # Misclassification error rate: 0.02057   | Residual mean deviance: 0.1669
tree.train <- tree(progr ~., data=x_train)
rm(list=ls())
# Load Dataset ------------------------------------------------------------
{
library(tidyverse)
library(ISLR2)
library(glmnet)
library(readr)
library(tree)
library(randomForest)
library(gbm)
}
{
dataf <- read_delim("db.txt",delim = "\t", escape_double = FALSE, trim_ws = TRUE)
}
#View(dataf)
head(dataf)
# Data Preprocessing ------------------------------------------------------
# Data Exploration --------------------------------------------------------
#cor(dataf)
#library('corrplot')
#cor_matrix <- cor(dataf)
#corrplot(cor_matrix, method = "color", type = "upper", tl.col = "black", tl.srt = 45, mar = c(0, 0, 1, 0), tl.cex = 0.7)
# Nota: HDL (TCH)con tutto, CD-LDL
# Data Split --------------------------------------------------------------
{
set.seed(1)
train_idx <- sample(seq_len(nrow(dataf)), size = 0.5 * nrow(dataf))
train_df <- dataf[train_idx, ]
test_df  <- dataf[-train_idx, ]
train_df$progr <- as.numeric(train_df$progr)
test_df$progr  <- as.numeric(test_df$progr)
}
# Tree --------------------------------------------------------------------
set.seed(1)
tree.train <- tree(progr ~., data=dataf, subset=x_train)
tree.train <- tree(progr ~., data=train_df)
# Tree --------------------------------------------------------------------
set.seed(1)
tree.train <- tree(progr ~., data=train_df)
summary(tree.train) # Misclassification error rate: 0.02057   | Residual mean deviance: 0.1669
# deviance: 402
tree.train <- tree(progr ~., data=train_df, split="gini")
summary(tree.train) # Misclassification error rate: 0.01645   | Residual mean deviance: 0.0728
# deviance: 173.2
plot(tree.train)
text(tree.train, pretty=0) # add node labels
tree.train <- tree(progr ~., data=train_df)
summary(tree.train) # Misclassification error rate: 0.02057   | Residual mean deviance: 0.1669
# Tree --------------------------------------------------------------------
set.seed(1)
tree.train <- tree(progr ~., data = train_df)
summary(tree.train)
tree.train <- tree(progr ~., data = train_df, split = "gini")
summary(tree.train)
plot(tree.train)
text(tree.train, pretty = 0)
# Tree --------------------------------------------------------------------
set.seed(1)
tree.train <- tree(progr ~., data = train_df)
summary(tree.train)
tree.train <- tree(progr ~., data = train_df, split = "gini")
summary(tree.train)
if (length(unique(tree.train$where)) > 1) {
plot(tree.train)
text(tree.train, pretty = 0)
}
plot(tree.train)
# Tree --------------------------------------------------------------------
set.seed(2)
tree.train <- tree(progr ~., data = train_df)
summary(tree.train)
tree.train <- tree(progr ~., data = train_df, split = "gini")
summary(tree.train)
plot(tree.train)
tree.train <- tree(progr ~ ., data = train_df,
control = tree.control(nobs = nrow(train_df),
mincut = 1,
minsize = 2,
mindev = 0))
summary(tree.train)
plot(tree.train)
text(tree.train, pretty = 0)
View(train_df)
library(rsample)
set.seed(1)
data_split <- initial_split(dataf, prop=0.5)
x_train <- training(data_split)
x_test <- testing(data_split)
y_test <- x_test$progr
library(gbm)
set.seed(1)
boosted <- gbm(progr ~ ., data=x_train, distribution="gaussian",
n.trees=5000, interaction.depth=4)
knitr::kable(summary(boosted))
plot(boosted, i="TG")  # Replace "TG" with the variable name
plot(boosted, i="BP")  # Replace "BP" with another variable name
yhat.boost <- predict(boosted, newdata=x_test, n.trees=5000)
compute_mse <- function(preds, truth) {
mean((preds - truth)^2)
}
mse <- compute_mse(yhat.boost, y_test)
mse
boosted <- gbm(progr ~ ., data=x_train, distribution="gaussian",
n.trees=5000, interaction.depth=4, shrinkage=0.2)
yhat.boost2 <- predict(boosted, newdata=x_test, n.trees=5000)
mse2 <- compute_mse(yhat.boost2, y_test)
mse2
# Functions ---------------------------------------------------------------
compute_mse <- function(preds, truth) {
mean((preds - truth)^2)
}
set.seed(1)
boosted <- gbm(progr ~ ., data=x_train, distribution="gaussian", n.trees=5000, interaction.depth=4)
yhat.boost <- predict(boosted, newdata=x_test, n.trees=5000)
mse <- compute_mse(yhat.boost, y_test)
mse
boosted <- gbm(progr ~ ., data=x_train, distribution="gaussian",
n.trees=5000, interaction.depth=4, shrinkage=0.2)
yhat.boost2 <- predict(boosted, newdata=x_test, n.trees=5000)
mse2 <- compute_mse(yhat.boost2, y_test)
mse2
# Define a grid of hyperparameters
n_trees_grid <- c(1000, 2000, 3000, 5000)
interaction_depth_grid <- c(2, 4, 6)
shrinkage_grid <- c(0.01, 0.1, 0.2)
# Initialize variables to store the best results
best_mse <- Inf
best_params <- list()
# Manual grid search
for (n_trees in n_trees_grid) {
for (interaction_depth in interaction_depth_grid) {
for (shrinkage in shrinkage_grid) {
set.seed(1)
# Train the model with the current combination of hyperparameters
boosted <- gbm(progr ~ ., data = x_train, distribution = "gaussian",
n.trees = n_trees, interaction.depth = interaction_depth,
shrinkage = shrinkage, verbose = FALSE)
# Predict on the test set
yhat <- predict(boosted, newdata = x_test, n.trees = n_trees)
# Compute the MSE
mse <- compute_mse(yhat, y_test)
# Update the best parameters if the current MSE is lower
if (mse < best_mse) {
best_mse <- mse
best_params <- list(n_trees = n_trees, interaction_depth = interaction_depth, shrinkage = shrinkage)
}
}
}
}
# Print the best hyperparameters and the corresponding MSE
print(best_params)
print(best_mse)
