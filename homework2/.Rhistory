best_mse <- mse
best_params <- list(n_trees = n_trees, interaction_depth = interaction_depth, shrinkage = shrinkage)
}
}
}
}
# Print the best hyperparameters and the corresponding MSE
print(best_params)
print(best_mse)
plot(n.trees)
boosted <- gbm(progr ~ ., data=x_train, distribution="gaussian", n.trees=1000, interaction.depth=2, shrinkage=0.01)
yhat.boost2 <- predict(boosted, newdata=x_test, n.trees=1000)
mse <- compute_mse(yhat.boost2, y_test)
mse #3146.236
